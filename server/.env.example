# MongoDB Configuration
MONGO_URI=mongodb://mongodb:27017/soulsync
PORT=5000

# Security
JWT_SECRET=your-secure-jwt-secret-key-here
JOURNAL_ENCRYPTION_KEY=your-32-character-hex-encryption-key-here
NODE_ENV=development

# URLs (Update for production)
CLIENT_URL=http://localhost:5173
PYTHON_SERVER=http://python:8000

# Email Service (Gmail with App Password)
SENDER_EMAIL=your-email@gmail.com
SENDER_PASS=your-app-password-here

# Push Notifications (Web Push Keys)
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# External APIs
GROQ_API_KEY=your-groq-api-key-here

# Upstash Redis (Cloud Redis)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ImageKit (Optional - for image optimization)
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key-here
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key-here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-endpoint-here

# Twilio (Optional - for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890
